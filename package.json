{
  "name": "nonecap",
  "version": "0.2.0",
  "description": "Official TypeScript client for the NoneCap hCaptcha solving API.",
  "type": "module",
  "license": "MIT",
  "author": "Lunium",
  "homepage": "https://nonecap.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonecap/nonecap-js.git"
  },
  "bugs": {
    "url": "https://github.com/nonecap/nonecap-js/issues"
  },
  "keywords": [
    "nonecap",
    "hcaptcha",
    "captcha",
    "captcha-solver",
    "hcaptcha-solver",
    "api-client",
    "sdk",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
